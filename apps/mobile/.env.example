# Backend API base (versioned). Example: http://192.168.1.164:8099/api/v1
EXPO_PUBLIC_API_URL=

# Google sign-in: the OAuth 2.0 **Web** client id (…apps.googleusercontent.com).
# Passed to GoogleSignin.configure({ webClientId }) so the returned ID token's
# audience is the web client — which the backend's GOOGLE_MOBILE_AUDIENCES accepts.
# The Android OAuth client (package + SHA-1) is matched by Google automatically and
# is NOT referenced here. Client ids are public identifiers, not secrets.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
