{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "jest",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@beyou/types": [
        "../../packages/types/src"
      ],
      "@beyou/types/*": [
        "../../packages/types/src/*"
      ],
      "@beyou/i18n": [
        "../../packages/i18n/src"
      ],
      "@beyou/theme": [
        "../../packages/theme/src"
      ],
      "@beyou/state": [
        "../../packages/state/src"
      ],
      "@beyou/state/*": [
        "../../packages/state/src/*"
      ],
      "@beyou/api": [
        "../../packages/api/src"
      ],
      "@beyou/api/*": [
        "../../packages/api/src/*"
      ],
      "@beyou/contracts": [
        "../../packages/contracts/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ]
}
