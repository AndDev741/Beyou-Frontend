{
  "name": "@beyou/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@beyou/i18n": "*",
    "@beyou/theme": "*",
    "@expo/vector-icons": "^15.0.2",
    "@reduxjs/toolkit": "^2.12.0",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "i18next": "^23.16.8",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-i18next": "^15.7.4",
    "react-native": "0.85.3",
    "react-native-css-interop": "^0.2.5",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.3.3",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.15",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|expo-router|@beyou/.*|react-clone-referenced-element|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|uuid|@reduxjs/toolkit|react-redux|immer|i18next|react-i18next|@testing-library/.*|@hookform/.*|nativewind|tailwindcss|react-native-reanimated|react-native-safe-area-context|react-native-screens))"
    ],
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/src/__mocks__/fileMock.js",
      "^react$": "<rootDir>/node_modules/react",
      "^react-native-css-interop$": "<rootDir>/node_modules/react-native-css-interop",
      "^react-native-css-interop/(.*)": "<rootDir>/node_modules/react-native-css-interop/$1",
      "^react-test-renderer$": "<rootDir>/node_modules/react-test-renderer",
      "^react-test-renderer/(.*)": "<rootDir>/node_modules/react-test-renderer/$1"
    }
  },
  "private": true
}
