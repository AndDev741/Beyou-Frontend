{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@beyou/types": ["packages/types/src/index.ts"],
      "@beyou/types/*": ["packages/types/src/*"],
      "@beyou/i18n": ["packages/i18n/src/index.ts"],
      "@beyou/theme": ["packages/theme/src/index.ts"],
      "@beyou/state": ["packages/state/src/index.ts"],
      "@beyou/state/*": ["packages/state/src/*"],
      "@beyou/api": ["packages/api/src/index.ts"],
      "@beyou/api/*": ["packages/api/src/*"],
      "@beyou/contracts": ["packages/contracts/src/index.ts"],
      "@beyou/validation": ["packages/validation/src/index.ts"],
      "@beyou/validation/*": ["packages/validation/src/*"],
      "@beyou/icons": ["packages/icons/src/index.ts"],
      "@beyou/icons/*": ["packages/icons/src/*"],
      "@beyou/offline": ["packages/offline/src/index.ts"],
      "@beyou/offline/*": ["packages/offline/src/*"]
    }
  }
}
