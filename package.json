{
  "name": "beyou-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": ["apps/*", "packages/*"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "web": "npm --workspace @beyou/web run dev"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "@beyou/mobile": {
      "react": "19.2.3",
      "react-native": "0.85.3"
    },
    "react-native-reanimated": "4.3.1",
    "react-native-worklets": "0.8.3",
    "react-native-css-interop": "0.2.5"
  }
}
